                        "id": "bookstores",
                        "visible": true
                    }
                ]
            },
            "callout": "Clayton regularly appears among the top places to live and work in the Midwest — a rare combination of urban energy and suburban calm."
        },
        {
            "navLabel": "Webster Groves",
            "title": "Webster Groves — Victorian Character",
            "text": [
                "Webster Groves is one of Missouri's oldest suburbs, platted in the 1890s along the Frisco Railroad. Its streets of Victorian and Craftsman homes have changed little structurally, giving it an unusually intact historic fabric.",
                "Novel Neighbor and Kaldi's Coffee sit just blocks apart on Big Bend, forming one of the county's best casual literary corners."
            ],
            "scene": {
                "center": [
                    -90.356,
                    38.593
                ],
                "zoom": 14,
                "label": "Webster Groves, Missouri",
                "layers": [
