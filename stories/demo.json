        {
            "navLabel": "Clayton",
            "title": "Clayton — The County Seat",
            "text": [
                "Clayton is the seat of St. Louis County government and a major employment center in its own right. Its downtown — centered on Forsyth Boulevard — has evolved from a quiet administrative hub into a sophisticated urban village.",
                "The city punches above its weight: it has the density of a small downtown, an active restaurant and arts scene, and some of the county's most walkable blocks."
            ],
            "scene": {
                "center": [
                    -90.334,
                    38.644
                ],
                "zoom": 14,
                "label": "Clayton, Missouri",
                "layers": [
